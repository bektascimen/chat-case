# Server
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql://appnation:appnation@localhost:5432/appnation?connection_limit=10&pool_timeout=20

# Auth (dev only)
JWT_SECRET=dev-secret-replace-in-prod-please
APP_CHECK_TOKEN=mock-app-check-token

# AI Provider
AI_PROVIDER=mock                # mock | openai | gemini
OPENAI_API_KEY=
GEMINI_API_KEY=

# LLM Circuit Breaker
LLM_CIRCUIT_FAILURE_THRESHOLD=5
LLM_CIRCUIT_RESET_TIMEOUT_MS=30000
LLM_CIRCUIT_FALLBACK=mock        # mock | throw

# LLM Retry (wraps real providers; sits inside the circuit breaker)
LLM_RETRY_MAX_ATTEMPTS=3
LLM_RETRY_BASE_DELAY_MS=200
LLM_RETRY_MAX_DELAY_MS=5000
LLM_RETRY_JITTER_RATIO=0.2

# LLM request timeout (per call, via AbortSignal)
LLM_REQUEST_TIMEOUT_MS=30000

# Admin
ADMIN_TOKEN=dev-admin-token

# Feature Flags (override defaults)
# STREAMING_ENABLED=true
# PAGINATION_LIMIT=20
# AI_TOOLS_ENABLED=false
# CHAT_HISTORY_ENABLED=true
# RATE_LIMIT_PER_MINUTE=60
# COMPLETION_ENABLED=true
